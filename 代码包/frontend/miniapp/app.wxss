/* 全局样式 */
@import './images/icons.wxss';

page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #303133;
  background: #f5f7fa;
  --green: #67c23a;
  --green-dark: #1a6b3c;
  --red: #f56c6c;
  --orange: #e6a23c;
  --blue: #409eff;
}

/* 通用容器 */
.container {
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-bottom {
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

/* 绿色主题按钮 */
.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #67c23a 0%, #529b2e 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-primary[disabled] {
  opacity: 0.5;
}

/* 白色卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 页面标题 */
.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  padding: 30rpx 30rpx 10rpx;
}

/* flex 布局 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-1 {
  flex: 1;
}

/* 文字 */
.text-center { text-align: center; }
.text-right { text-align: right; }
.text-muted { color: #909399; font-size: 24rpx; }
.text-sm { font-size: 24rpx; }
.text-lg { font-size: 36rpx; font-weight: 700; }
.text-green { color: #67c23a; }
.text-red { color: #f56c6c; }
.text-orange { color: #e6a23c; }

/* 间距 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-20 { margin-bottom: 20rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

/* 分割线 */
.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 20rpx 0;
}

/* 加载中 */
.loading-tip {
  padding: 40rpx;
  text-align: center;
  color: #c0c4cc;
  font-size: 26rpx;
}
