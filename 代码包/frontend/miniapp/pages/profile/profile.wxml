<view class="prof-page">
  <view class="prof-hero">
    <view class="prof-avatar">
      <view class="icon icon-user-white" style="width:60rpx;height:60rpx"></view>
    </view>
    <text class="prof-name">{{userInfo.nickName || '刘阿姨'}}</text>
    <text class="prof-phone">{{maskPhone(userInfo.phone)}}</text>
    <view class="prof-stats">
      <view class="prof-stat-item"><text class="prof-stat-val">{{userStats.totalDeliveryTimes || 0}}</text><text class="prof-stat-label">累计投递</text></view>
      <view class="prof-stat-item"><text class="prof-stat-val">{{pointBalance}}</text><text class="prof-stat-label">积分余额</text></view>
      <view class="prof-stat-item"><text class="prof-stat-val">{{correctRateText}}%</text><text class="prof-stat-label">分类正确率</text></view>
    </view>
  </view>

  <view class="prof-report-card" bindtap="goReport">
    <view class="prc-left">
      <view class="icon icon-chart" style="width:44rpx;height:44rpx"></view>
      <view><text class="prc-title">6月分类报告</text><text class="prc-sub">已生成，点击查看详情</text></view>
    </view>
    <text class="prc-arrow">›</text>
  </view>

  <view class="prof-menu">
    <view class="prof-menu-item" bindtap="goPoints">
      <view class="icon icon-coins icon-lg"></view>
      <text class="pmi-label">积分明细</text>
      <text class="pmi-arrow">›</text>
    </view>
    <view class="prof-menu-item" bindtap="goDelivery">
      <view class="icon icon-list icon-lg"></view>
      <text class="pmi-label">投递记录</text>
      <text class="pmi-arrow">›</text>
    </view>
    <view class="prof-menu-item" bindtap="goMall">
      <view class="icon icon-gift icon-lg"></view>
      <text class="pmi-label">我的兑换</text>
      <text class="pmi-arrow">›</text>
    </view>
    <view class="prof-menu-item" bindtap="goRecognize">
      <view class="icon icon-camera icon-lg"></view>
      <text class="pmi-label">拍照查分类</text>
      <text class="pmi-arrow">›</text>
    </view>
  </view>

  <button class="prof-logout" bindtap="handleLogout">退出登录</button>
  <view class="safe-bottom"></view>
</view>
