/* 图标系统 - SVG data-uri 内嵌方式，无需外部依赖 */
.icon{display:inline-block;width:48rpx;height:48rpx;background-size:contain;background-repeat:no-repeat;background-position:center;flex-shrink:0}
.icon-sm{width:36rpx;height:36rpx}
.icon-lg{width:64rpx;height:64rpx}
.icon-xl{width:96rpx;height:96rpx}

