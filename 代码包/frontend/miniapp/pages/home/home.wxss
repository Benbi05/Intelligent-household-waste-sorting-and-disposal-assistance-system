.home-page{min-height:100vh;background:#F7FAF8;padding:0 24rpx;max-width:750rpx;margin:0 auto;}

/* 问候卡 */
.greeting-card{
  background:#fff;border-radius:24rpx;padding:28rpx 24rpx;
  display:flex;justify-content:space-between;align-items:center;
  margin-top:20rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.04);
}
.greeting-left{display:flex;align-items:center;gap:16rpx;}
.avatar-circle{
  width:96rpx;height:96rpx;border-radius:50%;background:linear-gradient(135deg,#67c23a,#529b2e);
  display:flex;align-items:center;justify-content:center;
}
.avatar-icon{font-size:48rpx;}
.greeting-name{font-size:32rpx;font-weight:600;color:#1A261D;display:block;}
.points-inline{display:flex;align-items:center;gap:6rpx;margin-top:6rpx;}
.trophy{font-size:24rpx;}
.points-num{font-size:26rpx;color:#67c23a;font-weight:600;}
.greeting-date{font-size:24rpx;color:#8AAB93;}

/* 快捷操作 */
.quick-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16rpx;margin-top:20rpx;}
.quick-item{
  background:#fff;border-radius:20rpx;padding:28rpx 0;text-align:center;
  box-shadow:0 2rpx 12rpx rgba(0,0,0,.04);min-height:160rpx;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
}
.quick-item:active{transform:scale(.96);transition:transform .15s;}
.quick-icon-box{
  width:88rpx;height:88rpx;border-radius:22rpx;display:flex;
  align-items:center;justify-content:center;margin-bottom:12rpx;
}
.qi-icon{font-size:44rpx;}
.qi-label{font-size:26rpx;font-weight:500;color:#1A261D;}

/* 区域 */
.section{margin-top:24rpx;}
.section-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16rpx;}
.section-title{font-size:30rpx;font-weight:600;color:#1A261D;}
.section-link{font-size:26rpx;color:#67c23a;}

/* 分类指南 */
.guide-grid{display:grid;grid-template-columns:1fr 1fr;gap:16rpx;}
.guide-card{
  background:#fff;border-radius:16rpx;padding:20rpx;display:flex;align-items:center;gap:16rpx;
  border-left:6rpx solid #ccc;box-shadow:0 2rpx 8rpx rgba(0,0,0,.03);
}
.guide-icon-box{
  width:72rpx;height:72rpx;border-radius:18rpx;display:flex;align-items:center;justify-content:center;
}
.guide-icon{font-size:36rpx;}
.guide-cat-name{font-size:28rpx;font-weight:600;display:block;}
.guide-cat-desc{font-size:22rpx;color:#8AAB93;margin-top:4rpx;display:block;}

/* 投放记录 */
.activity-card{background:#fff;border-radius:20rpx;overflow:hidden;box-shadow:0 2rpx 8rpx rgba(0,0,0,.03);}
.activity-item{display:flex;align-items:center;padding:24rpx;gap:16rpx;border-bottom:1rpx solid #F3F4F6;}
.activity-item:last-child{border-bottom:none;}
.act-icon-box{
  width:72rpx;height:72rpx;border-radius:18rpx;display:flex;align-items:center;
  justify-content:center;font-size:34rpx;flex-shrink:0;
}
.act-info{flex:1;}
.act-name{font-size:28rpx;color:#1A261D;display:block;}
.act-time{font-size:22rpx;color:#8AAB93;margin-top:4rpx;display:block;}
.act-points{font-size:30rpx;font-weight:700;}

.safe-bottom{height:120rpx;}
