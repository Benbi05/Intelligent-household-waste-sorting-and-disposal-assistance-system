.navbar {
  width: 100%;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 999;
  background: linear-gradient(135deg, #1a6b3c 0%, #0d5e3a 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}
.navbar-title {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}
